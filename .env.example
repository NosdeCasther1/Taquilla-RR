# Conexión a TiDB (MySQL-compatible). En TiDB Cloud usa sslaccept=strict.
DATABASE_URL="mysql://usuario:password@host:4000/taquilla_rr?sslaccept=strict"

# Secreto de Auth.js. Genera uno con: npx auth secret  (o: openssl rand -base64 32)
AUTH_SECRET="cambia-este-secreto"

# URL pública de la app (local o Vercel). Ayuda a Auth.js a fijar la cookie.
AUTH_URL="http://localhost:3000"

# Opcional: contraseña del admin del seed. Si se omite, usa "admin123".
# No pongas comillas vacías (""): eso deja la contraseña en blanco.
# SEED_ADMIN_PASSWORD=tu-password-segura
